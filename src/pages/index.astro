---
import Ecrou from '../components/atoms/Ecrou.astro';
import ElementalCircle from '../components/atoms/ElementalCircle.astro';
import JapaneseWord from '../components/atoms/JapaneseWord.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro</title>
  </head>
  <body>
    <div class="card-container">
      <h1 class="titles">
        <span>Gros, large</span>
        <ElementalCircle color="#018cc4">大</ElementalCircle>
      </h1>
      <div class="rectangle">
        <img
          src="https://archives.bulbagarden.net/media/upload/thumb/5/56/Sleep_Key_Art.jpg/1024px-Sleep_Key_Art.jpg"
          alt=""
        />
      </div>

      <!--Pronontionnations -->
      <div class="attack">
        <dl class="kunyomi">
          <dt><ElementalCircle color="orange">训</ElementalCircle></dt>
          <dd>おお-</dd>
          <dd>おおきい</dd>
          <dd>おおいに</dd>
        </dl>
        <dl>
          <dt><ElementalCircle color="#018cc4">音</ElementalCircle></dt>
          <dd>ダイ</dd>
          <dd>タイ</dd>
        </dl>
      </div>

      <!-- Exmple de mots -->
      <div class="exemples-box">
        <Ecrou /><h3>Exemples de mots</h3><Ecrou />

        <div class="mots">
          <dl class="mot">
            <dt>Université</dt>
            <dd>
              <JapaneseWord
                characters={[
                  { char: '大', furigana: 'だい' },
                  { char: '学', furigana: 'がく' },
                ]}
              />
            </dd>
          </dl>

          <dl class="mot">
            <dt>Université</dt>
            <dd>
              <JapaneseWord
                characters={[
                  { char: '大', furigana: 'だい' },
                  { char: '学', furigana: 'がく' },
                ]}
              />
            </dd>
          </dl>
        </div>

        <Ecrou /><Ecrou />
      </div>
    </div>
  </body>
</html>

<style lang="scss" is:global>
  h2 {
    margin: 0;
  }
  .card-container {
    --card-width: 630px;
    display: flex;
    flex-direction: column;
    aspect-ratio: 5 / 7;
    width: var(--card-width);
    border: calc(var(--card-width) * 0.048) solid #f0c000;
    border-bottom-width: calc(var(--card-width) * 0.06349);
    background-color: red;
    background-image: url(/img/grunge-wall-texture.jpg);
    background-size: cover;
    border-radius: calc(var(--card-width) * 0.048);
    box-sizing: border-box;

    & .attack {
      padding-top: 5%;
      & > dl {
        display: flex;
        margin-inline: 2%;
        padding-inline: 3%;
        border-bottom: 2px solid #000;
        padding-bottom: 2%;
      }
    }

    & .titles {
      display: flex;
      justify-content: space-between;
      width: calc(var(--card-width) * 0.79365);
      margin-inline: auto;
    }

    & img {
      display: block;
      object-fit: cover;
      aspect-ratio: 25 / 18;
      width: 96%;
      margin: 0 auto;
      box-sizing: border-box;
    }

    & .rectangle {
      display: grid;
      place-content: center;
      background: conic-gradient(
        from 33deg,
        #ffcc00,
        #b99400,
        #ffcc00,
        #b99400,
        #ffcc00
      );
      width: calc(var(--card-width) * 0.79365);
      aspect-ratio: 25 / 18;
      margin-inline: auto;

      box-shadow: 7px 7px 25px 2px #000;
    }

    .exemples-box {
      box-sizing: border-box;
      flex: 1;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      grid-template-rows: 1fr auto 1fr;
      justify-content: space-between;
      margin-inline: auto;
      margin-bottom: 1rem;
      padding: 5px;
      width: 96%;
      background-image: url(https://i.pinimg.com/736x/a0/f6/28/a0f628fe84b0a1f75b3345dc13e9d126.jpg);
      border: 4px solid #ccc;
      border-right-color: #aaa;
      border-bottom-color: #aaa;
      background-color: #ccc;

      & > *:nth-child(3),
      & > *:nth-child(6) {
        justify-self: end;
      }
      & > *:nth-child(4) {
        grid-column: 1 / span 3;
      }

      & > *:nth-child(5),
      & > *:nth-child(6) {
        align-self: end;
      }

      & > *:nth-child(6) {
        grid-column: 3;
      }

      & h3 {
        margin: 0;
      }
    }

    .mots {
      display: flex;
      justify-content: center;
      column-gap: 1.25rem;

      .mot {
        width: fit-content;
        display: flex;
        flex-direction: column;

        & dd {
          margin-inline: auto;
        }
      }
    }
  }
</style>
